{
  "name": "neardrop",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.0",
  "workspaces": ["frontend", "backend", "packages/*"],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "RUN_DB_INTEGRATION=1 npm run test:integration --workspace=@neardrop/api",
    "test:coverage": "turbo run test:coverage",
    "migrate": "npm run migrate --workspace=@neardrop/api",
    "migrate:rollback": "npm run migrate:rollback --workspace=@neardrop/api",
    "migrate:latest": "npm run migrate:latest --workspace=@neardrop/api",
    "record:phase0-evidence": "bash scripts/record-phase-gates.sh",
    "test:e2e:web": "npm run test:e2e --workspace=@neardrop/web",
    "e2e:full": "npm run migrate && npm run test:e2e:web",
    "seed:demo": "npm run seed:demo --workspace=@neardrop/api",
    "test:phase8-count-gate": "node scripts/turbo-test-min-count.mjs",
    "verify:all": "npm run typecheck && npm run lint && npm run test && npm run migrate && npm run migrate:rollback && npm run migrate && npm run test:integration && npm run build && npm run test:phase8-count-gate && npm run test:e2e:web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.1",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  },
  "engines": {
    "node": ">=20"
  }
}
