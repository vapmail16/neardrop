# Copy to .env and fill values. Never commit .env.

# API
NODE_ENV=development
PORT=3010
HOST=0.0.0.0
LOG_LEVEL=info

# PostgreSQL (required for dev/staging/prod — omit only in unit tests with mocks)
# SCRAM: use postgresql://user:password@host:port/db (TCP). Create role+DB (see README).
# Example when Postgres listens on 5432:
DATABASE_URL=postgresql://neardrop:neardrop@127.0.0.1:5432/neardrop

# JWT — minimum 32 characters; access/refresh lifetimes (jsonwebtoken `expiresIn` format)
JWT_SECRET=replace-with-at-least-32-character-secret-key
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
# Collection QR JWT (handover token; jsonwebtoken `expiresIn` format)
JWT_QR_COLLECTION_EXPIRES=7d

# bcrypt cost (minimum 12 per security checklist)
BCRYPT_ROUNDS=12

# CORS origin for web app (must match where the browser loads the Next app — default dev is 3020)
CORS_ORIGIN=http://localhost:3020

# Set to 1 only for local Playwright E2E or many scripted logins; never in production.
# DISABLE_LOGIN_RATE_LIMIT=0

# Next.js / Playwright env belongs in frontend/.env.local — see ../frontend/.env.example
