# Copy to `.env.local` in this folder only — never commit (see root `.gitignore`).
# Backend secrets (DATABASE_URL, JWT_SECRET, etc.) live in `backend/.env` only.

# Upstream API for Next.js rewrites and server-side layout auth (must match where the API listens).
API_UPSTREAM=http://127.0.0.1:3010

# Optional: absolute API URL for client-side calls if you use NEXT_PUBLIC_* fetches
# NEXT_PUBLIC_API_URL=http://127.0.0.1:3010
