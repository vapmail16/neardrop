{
  "name": "@neardrop/web",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "cross-env NODE_ENV=production next build",
    "clean": "rm -rf .next",
    "dev": "sh -c 'ulimit -n 10240 2>/dev/null || true; exec next dev -p 3020'",
    "sync:shared": "node scripts/sync-shared.mjs",
    "start": "next start",
    "lint": "eslint -c eslint.config.js \"src/**/*.{ts,tsx}\" \"playwright.config.mjs\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:file": "vitest run",
    "test:e2e": "playwright test -c playwright.config.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "verify:release": "npm run lint && npm run typecheck && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@neardrop/shared": "file:./packages/shared",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-qr-code": "^2.0.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
